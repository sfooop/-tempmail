{
  "buildCommand": "pnpm install && pnpm run build",
  "outputDirectory": "artifacts/tempmail/dist",
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!assets|_next|public).*)*",
      "destination": "/index.html"
    }
  ]
}
